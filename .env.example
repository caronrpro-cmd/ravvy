# ─────────────────────────────────────────────────────────────────────────────
# PartySync — Variables d'environnement
#
# Copiez ce fichier en .env et renseignez les valeurs :
#   cp .env.example .env
#
# ⚠️  Ne commitez JAMAIS le fichier .env (il est dans .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Authentification OAuth (Manus) ───────────────────────────────────────────

# URL du portail OAuth Manus (ex : https://auth.manus.space)
# Requis pour toutes les connexions (email, Apple, Facebook, Instagram)
EXPO_PUBLIC_OAUTH_PORTAL_URL=

# URL du serveur OAuth Manus
EXPO_PUBLIC_OAUTH_SERVER_URL=

# Identifiant de l'application dans le portail Manus
EXPO_PUBLIC_APP_ID=

# OpenID du propriétaire de l'app (pour les droits admin)
EXPO_PUBLIC_OWNER_OPEN_ID=

# Nom affiché du propriétaire
EXPO_PUBLIC_OWNER_NAME=

# ── API backend ───────────────────────────────────────────────────────────────

# URL de base de l'API Express (ex : http://localhost:3000)
# Laisser vide pour dériver automatiquement depuis window.location (web seulement)
EXPO_PUBLIC_API_BASE_URL=

# ── Backend (serveur Node/Express) ────────────────────────────────────────────

# URL complète de la base de données MySQL
# Format : mysql://user:password@host:port/database
DATABASE_URL=

# Secret pour signer les JWT de session (chaîne aléatoire longue)
JWT_SECRET=

# Même APP_ID que côté client (sans préfixe EXPO_PUBLIC_)
VITE_APP_ID=

# Même OAuth server URL que côté client
OAUTH_SERVER_URL=

# Même Owner OpenID que côté client
OWNER_OPEN_ID=

# ── APIs optionnelles ─────────────────────────────────────────────────────────

# Clé API Forge (IA intégrée), si utilisée
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
